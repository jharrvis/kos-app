# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth
AUTH_SECRET=your-auth-secret
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Google OAuth (legacy, use AUTH_GOOGLE_* above)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Mayar.id Payment Gateway
# Get API key from: https://web.mayar.id/api-keys
# For testing, use sandbox: https://web.mayar.club/api-keys
MAYAR_API_KEY=your-mayar-api-key
MAYAR_WEBHOOK_SECRET=your-mayar-webhook-secret

# Optional: Override API base URL (defaults to production)
# MAYAR_API_BASE_URL=https://api.mayar.club/hl/v1  # Sandbox
# MAYAR_API_BASE_URL=https://api.mayar.id/hl/v1    # Production (default)

# Vercel Cron Jobs
# Generate a secure random string for cron job authentication
# Use: openssl rand -base64 32
CRON_SECRET=your-cron-secret-key

# Resend Email Service
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
